# Dummy RDP server for e2e tests (see tests/rdp_tiles_e2e.rs).
#
# Plain xrdp with no session backend: it still completes the full RDP
# handshake (TLS via the snakeoil cert the package generates) and paints its
# own login screen, which is all the tests need — real bitmap updates flowing
# to the client. Nothing can actually log in, and nothing listens beyond the
# published port.
FROM debian:bookworm-slim
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends xrdp \
    && rm -rf /var/lib/apt/lists/*
EXPOSE 3389
CMD ["xrdp", "--nodaemon"]
