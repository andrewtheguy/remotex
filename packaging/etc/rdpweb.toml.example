# rdpweb configuration example
#
# The binary loads this file on startup (see src/config.rs). The config is
# global-only: --config <path> if given, else the installed
# <prefix>/etc/rdpweb.toml — no per-user or working-directory files. There are
# no environment variables — everything is configured here. Keep this file
# readable only by the service user — it holds credentials.
#
#   chmod 600 rdpweb.toml

[server]
# Listen address/port for the web UI (both optional; defaults shown).
#host = "127.0.0.1"
#port = 52380
# Directory of the built frontend. Defaults to share/rdpweb/web in the active
# version (or frontend/dist in a checkout). Only set to override.
#static_dir = ""

# Target profiles (at least one required). Each needs a unique name; serve a
# specific one with `rdpweb serve --target <name>` (default: the first).
[[targets]]
name = "example"
protocol = "rdp"           # required: "rdp" or "vnc"
host = "192.0.2.10"
# Default: the protocol's standard port (3389 for rdp, 5900 for vnc).
#port = 3389

# Credentials (used server-side only; never sent to the browser).
username = "Administrator"
password = "change-me"
# Optional domain (leave unset for a local account). RDP only.
#domain = ""

# Initial desktop size to request. RDP only — a VNC server dictates its size.
#width = 1280
#height = 800

# Security mode: "auto" (TLS+NLA, default), "nla" (NLA only), "tls" (no NLA).
# RDP only — VNC negotiates VncAuth (password set) or None per the handshake.
#security = "auto"

# A VNC target only needs host and (usually) a password; username, domain,
# width/height, and security are ignored.
# [[targets]]
# name = "mac-screen-sharing"
# protocol = "vnc"
# host = "10.0.0.2"
# password = "change-me"
