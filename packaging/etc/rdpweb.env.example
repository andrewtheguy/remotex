# rdpweb configuration example
#
# The binary loads this file on startup (see src/main.rs). Every RDPWEB_* value
# below can also be passed as a `--flag` or set in the real environment; those
# take precedence over this file. Keep this file readable only by the service
# user — it holds credentials.
#
#   chmod 600 rdpweb.env

# ── RDP target ───────────────────────────────────────────────────────────────
RDPWEB_RDP_HOST=192.0.2.10
RDPWEB_RDP_PORT=3389

# ── RDP credentials (used server-side only; never sent to the browser) ───────
RDPWEB_RDP_USERNAME=Administrator
RDPWEB_RDP_PASSWORD=change-me
# Optional domain (leave unset for a local account).
#RDPWEB_RDP_DOMAIN=

# ── Initial desktop size to request ──────────────────────────────────────────
RDPWEB_RDP_WIDTH=1280
RDPWEB_RDP_HEIGHT=800

# ── Security mode: auto (TLS+NLA, default), nla (NLA only), tls (no NLA) ──────
#RDPWEB_RDP_SECURITY=auto

# ── Web server bind (optional) ───────────────────────────────────────────────
#RDPWEB_HOST=127.0.0.1
#RDPWEB_PORT=52380

# ── Frontend location (optional) ─────────────────────────────────────────────
# Defaults to share/rdpweb/web in the active version. Only set to override.
#RDPWEB_STATIC_DIR=

# ── Logging (optional) ───────────────────────────────────────────────────────
#RUST_LOG=info
